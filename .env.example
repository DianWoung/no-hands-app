# =============================================================================
# AI E-COMMERCE ASSISTANT - ENVIRONMENT CONFIGURATION
#
# Instructions:
# 1. Create a copy of this file in the same directory (the project root).
# 2. Name the copy ".env".
# 3. Fill in your actual values below.
# =============================================================================

# --- REQUIRED: OpenAI API Key ---
# Used for the main chat agent and, if selected, for embeddings.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY_HERE"


# --- Optional: Main Chat Agent Configuration ---
# Use this to connect to local LLMs (e.g., http://localhost:11434/v1) or other providers.
OPENAI_API_BASE="https://api.openai.com/v1"
# The model to use for the main chat agent (e.g., gpt-4o, gpt-3.5-turbo).
OPENAI_MODEL_NAME="gpt-4o"


# --- Optional: Embeddings Configuration ---
# Choose your provider: "openai" (default) or "ollama" for local models.
EMBEDDINGS_PROVIDER="openai"

# -- OpenAI Embeddings Settings --
# The model to use for generating embeddings for the knowledge base.
# It's recommended to use a dedicated, efficient embedding model.
OPENAI_EMBEDDINGS_MODEL_NAME="text-embedding-3-small"

# -- Ollama (Local Model) Embeddings Settings --
# The base URL for your Ollama service.
# If running with docker-compose, use the service name: http://ollama:11434
# If running manually, use localhost: http://localhost:11434
OLLAMA_BASE_URL="http://ollama:11434"
# The name of the local embeddings model you want to use (e.g., "nomic-embed-text").
# Make sure you have pulled this model with `docker exec -it ollama ollama pull nomic-embed-text`
OLLAMA_EMBEDDINGS_MODEL_NAME="nomic-embed-text"