# -----------------------------------------------------------------------------
# AI Service Configuration
#
# This file provides a template for configuring the AI services.
# To use it, create a copy named ".env" in the same directory and fill in
# your actual values.
# -----------------------------------------------------------------------------

# Your API key from OpenAI or a compatible service provider.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY_HERE"

# (Optional) The base URL of the AI service.
# Defaults to OpenAI's public API. Use this to connect to local LLMs
# (e.g., http://localhost:11434/v1) or other cloud providers.
OPENAI_API_BASE=https://api.openai.com/v1

# The model to use for the main chat agent (e.g., gpt-4o, gpt-3.5-turbo).
OPENAI_MODEL_NAME=gpt-4o

# The model to use for generating embeddings for the knowledge base.
# It's recommended to use a dedicated, efficient embedding model.
OPENAI_EMBEDDINGS_MODEL_NAME=text-embedding-3-small